local function CheckAdmins()
    local adminFound = "なし"
    for _, player in ipairs(Players:GetPlayers()) do
        -- グループランクや特定のバッジ、IsFriendsWith(1)などで判定可能だが、一般的にはIsA("Player")
        -- ここでは簡略化して名前や特定のプロパティでチェックするロジックを組む
